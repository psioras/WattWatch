{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"},
      {
        "Name": "File",
        "Args": {
          "path": "Logs/wattwatch-.txt",
          "rollingInterval": "Day",
          "returnedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost:5433;Database=mydatabase;User Id=admin;Password=My_Password1!;"
  },
  "ApiKeySettings": {
    "ApiKey": ""
  }
}
